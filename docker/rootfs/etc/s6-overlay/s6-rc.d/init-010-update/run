#!/command/with-contenv /bin/bash
# shellcheck shell=bash

function INFO() {
    echo -e "[\033[32mINFO\033[0m] ${1}"
}
function ERROR() {
    echo -e "[\033[31mERROR\033[0m] ${1}"
}
function WARN() {
    echo -e "[\033[33mWARN\033[0m] ${1}"
}

function deps_hash() {
    sha256sum pyproject.toml uv.lock | sha256sum | awk '{print $1}'
}

function ensure_uv() {
    if command -v uv >/dev/null 2>&1; then
        return 0
    fi
    INFO "检测到uv未安装，正在安装..."
    if [ "${NASTOOL_CN_UPDATE}" = "true" ]; then
        python -m pip install uv -i "${PYPI_MIRROR}"
    else
        python -m pip install uv
    fi
}

function install_python_build_deps() {
    if grep -Eqi "Debian" /etc/issue || grep -Eq "Debian" /etc/os-release; then
        apt-get update -y
        apt-get install -y build-essential libffi-dev libxml2-dev libxslt1-dev
    else
        apk add --no-cache libffi-dev gcc musl-dev libxml2-dev libxslt-dev
    fi
}

function sync_python_deps() {
    ensure_uv || return 1
    if [ "${NASTOOL_CN_UPDATE}" = "true" ] && [ -n "${PYPI_MIRROR}" ]; then
        export UV_DEFAULT_INDEX="${PYPI_MIRROR}"
    else
        unset UV_DEFAULT_INDEX
    fi
    uv export --frozen --no-dev --no-hashes --no-emit-project -o /tmp/requirements.txt || return 1
    uv pip install --system -r /tmp/requirements.txt || return 1
    if [ "${NASTOOL_CN_UPDATE}" = "true" ]; then
        python -m pip install feapder==1.9.2 --no-deps -i "${PYPI_MIRROR}" || return 1
    else
        python -m pip install feapder==1.9.2 --no-deps || return 1
    fi
}

# 更换国内软件源
function package_cn {

    cp /etc/apk/repositories /etc/apk/repositories.bak
    sed -i "s/dl-cdn.alpinelinux.org/${ALPINE_MIRROR}/g" /etc/apk/repositories
    apk update -f
    if [ $? -ne 0 ]; then
        ERROR "无法更换软件源，请更新镜像！"
        cp /etc/apk/repositories.bak /etc/apk/repositories
    fi

}
function package_cn_debian {

    cp /etc/apt/sources.list /etc/apt/sources.list.bak
    echo "deb https://mirrors.tuna.tsinghua.edu.cn/debian/ bookworm main contrib non-free non-free-firmware" > /etc/apt/sources.list
    echo "deb https://mirrors.tuna.tsinghua.edu.cn/debian/ bookworm-updates main contrib non-free non-free-firmware" >> /etc/apt/sources.list
    echo "deb https://mirrors.tuna.tsinghua.edu.cn/debian/ bookworm-backports main contrib non-free non-free-firmware" >> /etc/apt/sources.list
    echo "deb https://security.debian.org/debian-security bookworm-security main contrib non-free non-free-firmware" >> /etc/apt/sources.list
    apt-get update -y
    if [ $? -ne 0 ]; then
        ERROR "无法更换软件源，请更新镜像！"
        cp /etc/apt/sources.list.bak /etc/apt/sources.list
    fi

}

# 软件包更新
function package_update {

    if grep -Eqi "Debian" /etc/issue || grep -Eq "Debian" /etc/os-release; then
        if [ "${NASTOOL_CN_UPDATE}" = "true" ]; then
            package_list_debian_url=https://ghproxy.com/https://raw.githubusercontent.com/iMMIQ/nas-tools/master/package_list_debian.txt
        else
            package_list_debian_url=https://raw.githubusercontent.com/iMMIQ/nas-tools/master/package_list_debian.txt
        fi
        if [ ! -f /tmp/package_list_debian.txt ]; then
            curl -L ${package_list_debian_url} -o /tmp/package_list_debian.txt
        else
            rm -rf /tmp/package_list_debian.txt
            curl -L ${package_list_debian_url} -o /tmp/package_list_debian.txt
        fi
        if [ ! -s /tmp/package_list_debian.txt.sha256sum ]; then
            sha256sum /tmp/package_list_debian.txt > /tmp/package_list_debian.txt.sha256sum
        fi
        hash_old=$(cat /tmp/package_list_debian.txt.sha256sum)
        hash_new=$(sha256sum /tmp/package_list_debian.txt)
        if [ "${hash_old}" != "${hash_new}" ]; then
            DEBIAN_FRONTEND="noninteractive"
            INFO "检测到package_list.txt有变化，更新软件包..."
            if [ "${NASTOOL_CN_UPDATE}" = "true" ]; then
                package_cn_debian
            else
                apt-get update -y
            fi
            apt-get install -y $(echo $(cat /tmp/package_list_debian.txt))
            if [ $? -ne 0 ]; then
                ERROR "无法更新软件包，请更新镜像！"
            else
                INFO "软件包安装成功"
                sha256sum /tmp/package_list_debian.txt > /tmp/package_list.txt.sha256sum
            fi
        fi
    else
        hash_old=$(cat /tmp/package_list.txt.sha256sum)
        hash_new=$(sha256sum package_list.txt)
        if [ "${hash_old}" != "${hash_new}" ]; then
            INFO "检测到package_list.txt有变化，更新软件包..."
            if [ "${NASTOOL_CN_UPDATE}" = "true" ]; then
                package_cn
            fi
            apk add --no-cache $(echo $(cat package_list.txt))
            if [ $? -ne 0 ]; then
                ERROR "无法更新软件包，请更新镜像！"
            else
                INFO "软件包安装成功"
                sha256sum package_list.txt > /tmp/package_list.txt.sha256sum
            fi
        fi
    fi

}

# python库更新
function python_deps_update {

    hash_old=$(cat /tmp/uv-deps.sha256sum)
    hash_new=$(deps_hash)
    if [ "${hash_old}" != "${hash_new}" ]; then
        INFO "检测到pyproject.toml或uv.lock有变化，重新安装依赖..."
        if [ "${NASTOOL_CN_UPDATE}" = "true" ]; then
            if grep -Eqi "Debian" /etc/issue || grep -Eq "Debian" /etc/os-release; then
                package_cn_debian
            else
                package_cn
            fi
        fi
        install_python_build_deps
        sync_python_deps
        if [ $? -ne 0 ]; then
            ERROR "无法安装依赖，请更新镜像！"
            exit 1
        else
            INFO "依赖安装成功"
            deps_hash > /tmp/uv-deps.sha256sum
        fi
    fi

}

# feapder检查 - 确保feapder已安装
function feapder_check {

    if ! python -c "import feapder" 2>/dev/null; then
        INFO "检测到feapder未安装，正在安装..."
        if [ "${NASTOOL_CN_UPDATE}" = "true" ]; then
            python -m pip install feapder==1.9.2 --no-deps -i "${PYPI_MIRROR}"
        else
            python -m pip install feapder==1.9.2 --no-deps
        fi
        if [ $? -ne 0 ]; then
            ERROR "无法安装feapder，请更新镜像！"
        else
            INFO "feapder安装成功"
        fi
    fi

}

# third_party更新
function third_party_update {

    hash_old=$(cat /tmp/third_party.txt.sha256sum)
    hash_new=$(sha256sum third_party.txt)
    if [ "${hash_old}" != "${hash_new}" ]; then
        INFO "检测到third_party.txt有变化，更新第三方组件..."
        git submodule update --init --recursive
        if [ $? -ne 0 ]; then
            ERROR "无法更新第三方组件，请更新镜像！"
            exit 1
        else
            INFO "第三方组件安装成功"
            sha256sum third_party.txt > /tmp/third_party.txt.sha256sum
        fi
    fi

}

cd ${WORKDIR}

# 自动更新
if [ "${NASTOOL_AUTO_UPDATE}" = "true" ]; then
    if [ ! -s /tmp/uv-deps.sha256sum ]; then
        deps_hash > /tmp/uv-deps.sha256sum
    fi
    if [ ! -s /tmp/third_party.txt.sha256sum ]; then
        sha256sum third_party.txt > /tmp/third_party.txt.sha256sum
    fi
    if [ ! -s /tmp/package_list.txt.sha256sum ]; then
        sha256sum package_list.txt > /tmp/package_list.txt.sha256sum
    fi
    INFO "更新主程序..."
    git remote set-url origin "${REPO_URL}" &> /dev/null
    echo "windows/" > .gitignore
    if [[ "${NASTOOL_VERSION}" == "dev" ]]; then
        branch="dev"
    else
        branch="master"
    fi

    git clean -dffx
    git fetch --depth 1 origin ${branch}
    git reset --hard origin/${branch}

    if [ $? -eq 0 ]; then
        INFO "主程序更新成功"
        package_update
        python_deps_update
        feapder_check
        third_party_update
    else
        ERROR "更新失败，继续使用旧的程序来启动..."
    fi
else
    INFO "程序自动升级已关闭，如需自动升级请在创建容器时设置环境变量：NASTOOL_AUTO_UPDATE=true"
fi
